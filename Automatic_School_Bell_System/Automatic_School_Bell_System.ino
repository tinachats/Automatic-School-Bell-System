// function for horizontally centering the text on the display
void centerText(String text, int textSize, int maxCols, int row){
  // get the length of the menu item
  const int textLength = text.length();
  // horizontally center the text
  const int col = (48 - textLength) / 2; // using the column length of 48 for the nokia 5110
  // set the cursor on the positions
  lcd.setCursor(col, row);
  // set the font size
  lcd.setTextSize(textSize);
  // print the text
  lcd.print(text);
}