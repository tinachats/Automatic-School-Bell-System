void setup() {
  // set the lcd led pin as an output
  pinMode(lcdLedPin, OUTPUT);

  // set buzzer as an output
  pinMode(buzzer, OUTPUT);

  // initialize the buttons as inputs
  menuButton.begin();
  upButton.begin();
  downButton.begin();
  selectButton.begin();

  // start serial communication
  Serial.begin(9600);

  if (! rtc.begin()) {
    Serial.println("Couldn't find RTC");
    Serial.flush();
    while (1) delay(10);
  }

  if (rtc.lostPower()) {
    Serial.println("RTC lost power, let's set the time!");
    // When time needs to be set on a new device, or after a power loss, the
    // following line sets the RTC to the date & time this sketch was compiled
    rtc.adjust(DateTime(F(__DATE__), F(__TIME__)));
    // This line sets the RTC with an explicit date & time, for example to set
    // January 21, 2014 at 3am you would call:
    // rtc.adjust(DateTime(2014, 1, 21, 3, 0, 0));
  }

  // initialize the lcd
  lcd.begin(maxCols, maxRows);  

  // lcd.setFont(&FreeMono9pt7b); // set the font style of the lcd
  lcd.clearDisplay(); // clear the buffer
  lcd.setContrast(contrast); //Set contrast to 50
  lcd.drawBitmap(0, 0, logo, 84, 40, BLACK); // display the app logo
  lcd.setCursor(8, 40);
  lcd.setTextSize(1);
  lcd.print("Visionaries");
  lcd.display();  
}

void loop() {
  // get current temperature
  float temp = rtc.getTemperature();

  // get current time
  DateTime now = rtc.now();
  
  // get current seconds 
  sec = now.second();

  // get current minutes 
  min = now.minute();

  // get current hour
  hour = now.hour();

  // get today's date
  dt = now.day();

  // get current month
  mnth = now.month();

  // get current year
  year = now.year();

  // get today's day as a string
  date = daysOfTheWeek[now.dayOfTheWeek()];

  // get month as a string
  month = monthsOfTheYear[mnth - 1];

  // show the home screen
  homescreen(temp, sec, min, hour, dt, year, date, month);
}

// get the length of the number of items in an array of any data type
int arrayLength(char arr){
  //*(&arr + 1) is the address of the next memory location
  // just after the last element of the array
  int arrLength = *(&arr + 1) - arr;
  return arrLength;
}

// make sure every single digit is turned into a double digit
String pad(int n){
  String s = String(n);
  return (s.length() < 2 ? ("0" + s) : s);
}

// function to determine the meridian
String timeMeridian(int hour){
  String tm = "";
  return (hour < 12 ? tm = "am" : tm = "pm");
}

// display the home screen 
void homescreen(float temp, int sec, int min, int hour, int dt, int year, String date, String month){
  // clear the buffer
  lcd.clearDisplay();
  lcd.setTextSize(1);
  lcd.setCursor(9, 0);
  lcd.print(date + ", " + pad(dt) + " " + month);
  lcd.setTextSize(2);
  lcd.setCursor(6, 12);
  lcd.print(pad(hour) + ":" + pad(min));
  lcd.setCursor(66, 12);
  lcd.setTextSize(1);
  lcd.print(pad(sec));
  lcd.setTextSize(1);
  lcd.setCursor(66, 19);
  lcd.print(timeMeridian(hour));
  alarmActive(sec, min, hour, date); // activate the alarm based on date and time
  lcd.setTextSize(1);
  lcd.setCursor(0, 40);
  lcd.print(temp, 0);
  lcd.setCursor(10, 35);
  lcd.write(248);
  lcd.setCursor(14, 40);
  lcd.setTextSize(1);
  lcd.print("C");
  lcd.setTextSize(1);
  lcd.setCursor(60, 40);
  lcd.print("Menu");
  lcd.display();
}

// ring the alarm
void alarmActive(int sec, int min, int hour, String date){
  // make sure the alarm is not ringing during weekends
  // if(date != "Sat" || date != "Sun"){
  if(date == "Thu"){
    if(min == 48 && hour == 8 && sec == 0){
      sirenOn();
    } else {
      sirenOff();
    }
  }
}

// turn on the siren
void sirenOn(){
  // show the bell icon on the display
  lcd.drawBitmap(18, 14, bellIcon, 45, 46, BLACK);
  // sound the alarm
  digitalWrite(buzzer, HIGH);
}

// turn off the siren
void sirenOff(){
  // show the bell icon on the display
  lcd.drawBitmap(18, 14, clearBellIcon, 45, 46, BLACK);
  // sound the alarm
  digitalWrite(buzzer, LOW);
}

